# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Transit feed caches (downloaded GTFS zips + derived transfer graph)
data/*/transit/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/


# Added by cargo
/target

# Project specific
data/
# Exception: geocode shipped tiny models (small, checked-in Phase-0
# baselines per #96 §Confidence Model and #98 §Tagger).
!geocode/data/
!geocode/data/models/
!geocode/data/models/.gitkeep
!geocode/data/models/*
*.log
.env.local

# Downloaded OSM files - these are large data files that shouldn't be committed
*.osm.pbf
*.pbf

# Test output files
/tmp/test-*.pbf

# Temporary files
*.tmp
*~
.DS_Store

# Profiling
perf.data
perf.data.old
flamegraph.svg
*.perf

# Benchmark output
bench_results/
*.arrow
*.ipc

# Isochrone output files
isochrone*.geojson
batch_isochrone/

# CCH build temporaries (normally cleaned up, but just in case)
shortcuts.tmp

# Docker
.dockerignore

# IDE
.vscode/
.idea/

# Package files (generated by build scripts)
*.deb
*.deb.sha256
*.tar.gz
*.tar.gz.sha256
*.zip
*.zip.sha256
butterfly-dl-v*-*/
package_summary.md

# Release artifacts
releases/

# External comparison data (Valhalla tiles)
valhalla_tiles/
.claude/
.venv/
.codex

# Geocode research scratch projects: their own target/ and lockfiles
geocode-research/scratch-*/target/
geocode-research/scratch-*/Cargo.lock

# Geocode training generator: target/, lockfile, and any non-fixture corpus output
geocode-training/corpus-gen/target/
geocode-training/corpus-gen/Cargo.lock
geocode-training/phase2/target/
geocode-training/phase2/Cargo.lock
geocode-training/output/
geocode-training/*.jsonl

# Bench geocode results (generated by the bench scripts).
# Exception: the 2026-05-06 recall+rerank fixture summary is kept as
# a baseline against the post-libpostal redesign (#205).
bench/geocode/results/
!bench/geocode/results/2026-05-06-recall-rerank-fixture/
!bench/geocode/results/2026-05-06-recall-rerank-fixture/summary.json
# #88+#89 multi-country bench: keep summaries (markdown + JSON), drop
# the per-query rows (large + can be regenerated from rerun).
!bench/geocode/results/2026-05-06-multi-country-v2/
bench/geocode/results/2026-05-06-multi-country-v2/server.log
bench/geocode/results/2026-05-06-multi-country-v2/*/butterfly-rows.jsonl
bench/geocode/results/2026-05-06-multi-country-v2/*/nominatim-rows.jsonl
bench/geocode/.venv/

# AI consultation stderr (verbose progress logs; the .txt outputs are kept)
geocode-research/*.err

# Generated geocode shards (BFGS v5). 10-200 MB per country — produced
# by `butterfly-geocode build-shard` and rebuilt from PBFs / OA feeds
# as needed.
geocode/regions/*.bfgs
geocode/regions/*/*.bfgs

# Recall index sidecars (#205) — emitted next to each .bfgs by
# `butterfly-geocode build-shard` / `build-recall-index`. Sized
# proportionally to the shard (Belgium: ~70 MB FST + ~25 MB postings).
geocode/regions/*.recall.fst
geocode/regions/*.recall.postings
geocode/regions/*.recall.stats.json
geocode/regions/*/*.recall.fst
geocode/regions/*/*.recall.postings
geocode/regions/*/*.recall.stats.json
geocode/data/shards/*.recall.fst
geocode/data/shards/*.recall.postings
geocode/data/shards/*.recall.stats.json

# Per-region downloaded OpenAddresses payloads (under geocode/data/
# when tests place fixtures there for `cargo test --test ...
# --ignored`). The shipped tiny .gitkeep'd subdirs above
# (geocode/data/models, geocode/data/packs, geocode/data/proof) are
# explicitly NOT gitignored — only the address bulk downloads.
geocode/data/belgium/
geocode/data/us/
geocode/data/au/
geocode/data/jp/
geocode/data/br/
